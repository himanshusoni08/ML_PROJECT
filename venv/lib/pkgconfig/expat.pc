prefix=/Users/himanshu/Desktop/ML_project/venv
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: expat
Version: 2.7.5
Description: expat XML parser
URL: https://libexpat.github.io/
Libs: -L${libdir} -lexpat
Libs.private: -lm
Cflags: -I${includedir}
Cflags.private: -DXML_STATIC
